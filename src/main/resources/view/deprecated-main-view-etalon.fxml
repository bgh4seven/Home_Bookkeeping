<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="MainController"
            stylesheets="/styles/main.css">

    <top>
        <MenuBar>
            <Menu text="Файл">
                <MenuItem text="Выход" onAction="#handleExit"/>
            </Menu>
            <Menu text="Справка">
                <MenuItem text="О программе" onAction="#handleAbout"/>
                <MenuItem text="Тест бэкенда" onAction="#handleTestBackend"/>
            </Menu>
        </MenuBar>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <Label text="Добро пожаловать!" style="-fx-font-size: 24px;"/>
            <Label text="Здесь будет основной контент приложения"/>
            <Button text="Пример кнопки" onAction="#handleDemoButton"/>
        </VBox>
    </center>

    <bottom>
        <HBox style="-fx-padding: 10; -fx-background-color: #f0f0f0;">
            <Label fx:id="statusLabel" text="Готов к работе"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="dateLabel" text=""/>
        </HBox>
    </bottom>

</BorderPane>