<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0" prefHeight="768.0" prefWidth="1024.0" stylesheets="/styles/main.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.home_bookkeeping.frontend.MainController">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Вкладки занимают всё доступное место -->
                <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <!-- ==================== ВКЛАДКА "ДОХОДЫ" ==================== -->
                        <Tab text="Доходы">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                                    <children>
                                        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
                                            <children>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Button fx:id="addIncomeButton" mnemonicParsing="false" text="Добавить доход">
                                                            <HBox.margin>
                                                                <Insets left="10.0" />
                                                            </HBox.margin>
                                                        </Button>
                                                        <Button fx:id="deleteIncomeButton" mnemonicParsing="false" text="Удалить доход" />
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="incomeTable" prefHeight="229.0" prefWidth="513.0">
                                                    <columns>
                                                        <TableColumn fx:id="inc_numberColumn" prefWidth="50.0" text="№" />
                                                        <TableColumn fx:id="inc_amountColumn" prefWidth="150.0" text="Сумма" />
                                                        <TableColumn fx:id="inc_sourceColumn" prefWidth="313.0" text="Источник" />
                                                    </columns>
                                                </TableView>
                                                <!-- Блок выбора года, месяца и итога -->
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Label text="Год:" />
                                                    <ComboBox fx:id="inc_yearComboBox" prefWidth="100" />
                                                    <Label text="Месяц:" />
                                                    <ComboBox fx:id="inc_monthComboBox" prefWidth="150" />
                                                    <Label fx:id="inc_TotalLabel" text="Итого: 0 руб" style="-fx-font-weight: bold; -fx-text-fill: #2e8b57; -fx-padding: 0 0 0 20;" />
                                                </HBox>
                                                <!-- Гистограмма -->
                                                <BarChart fx:id="incomeChart" title="Сумма доходов по источникам" legendVisible="false">
                                                    <xAxis>
                                                        <NumberAxis label="Сумма (руб)" />
                                                    </xAxis>
                                                    <yAxis>
                                                        <CategoryAxis label="Источник" />
                                                    </yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                    </children>
                                </AnchorPane>
                            </content>
                        </Tab>

                        <!-- ==================== ВКЛАДКА "РАСХОДЫ" ==================== -->
                        <Tab text="Расходы">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                                    <children>
                                        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
                                            <children>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Button fx:id="addExpenseButton" mnemonicParsing="false" text="Добавить расход">
                                                            <HBox.margin>
                                                                <Insets left="10.0" />
                                                            </HBox.margin>
                                                        </Button>
                                                        <Button fx:id="deleteExpenseButton" mnemonicParsing="false" text="Удалить расход" />
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="expenseTable" prefHeight="229.0" prefWidth="513.0">
                                                    <columns>
                                                        <TableColumn fx:id="exp_numberColumn" prefWidth="50.0" text="№" />
                                                        <TableColumn fx:id="exp_amountColumn" prefWidth="150.0" text="Сумма" />
                                                        <TableColumn fx:id="exp_categoryColumn" prefWidth="313.0" text="Категория" />
                                                    </columns>
                                                </TableView>
                                                <!-- Блок выбора года, месяца и итога -->
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Label text="Год:" />
                                                    <ComboBox fx:id="exp_YearComboBox" prefWidth="100" />
                                                    <Label text="Месяц:" />
                                                    <ComboBox fx:id="exp_MonthComboBox" prefWidth="150" />
                                                    <Label fx:id="exp_TotalLabel" text="Итого: 0 руб" style="-fx-font-weight: bold; -fx-text-fill: #cc0000; -fx-padding: 0 0 0 20;" />
                                                </HBox>
                                                <!-- Гистограмма -->
                                                <BarChart fx:id="expenseChart" title="Сумма расходов по категориям" legendVisible="false">
                                                    <xAxis>
                                                        <NumberAxis label="Сумма (руб)" />
                                                    </xAxis>
                                                    <yAxis>
                                                        <CategoryAxis label="Категория" />
                                                    </yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                    </children>
                                </AnchorPane>
                            </content>
                        </Tab>

                        <!-- ==================== ВКЛАДКА "ВКЛАДЫ" (исправлены размеры диаграмм) ==================== -->
                        <Tab text="Вклады">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                                    <children>
                                        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
                                            <children>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Button fx:id="addDepositButton" mnemonicParsing="false" text="Добавить вклад">
                                                            <HBox.margin>
                                                                <Insets left="10.0" />
                                                            </HBox.margin>
                                                        </Button>
                                                        <Button fx:id="deleteDepositButton" mnemonicParsing="false" text="Удалить вклад" />
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="depositTable" prefHeight="229.0" prefWidth="513.0">
                                                    <columns>
                                                        <TableColumn fx:id="dep_numberColumn" prefWidth="50.0" text="№" />
                                                        <TableColumn fx:id="dep_bankColumn" prefWidth="113.0" text="Банк" />
                                                        <TableColumn fx:id="dep_amountColumn" prefWidth="100.0" text="Сумма" />
                                                        <TableColumn fx:id="dep_percentColumn" prefWidth="59.0" text="\%" />
                                                        <TableColumn fx:id="dep_srokColumn" prefWidth="80.0" text="Срок" />
                                                        <TableColumn fx:id="dep_startDateColumn" prefWidth="126.0" text="Дата открытия" />
                                                        <TableColumn fx:id="dep_endDateColumn" prefWidth="112.0" text="Дата погашения" />
                                                        <TableColumn fx:id="dep_expectedIncomeColumn" prefWidth="150.0" text="Ожидаемая доходность" />
                                                    </columns>
                                                </TableView>
                                                <!-- Общая сумма -->
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Label fx:id="depositTotalLabel" text="Общая сумма вкладов: 0 руб" style="-fx-font-weight: bold; -fx-text-fill: #1e90ff; -fx-padding: 5 0 5 10;" />
                                                </HBox>
                                                <!-- Диаграммы (исправлены размеры) -->
                                                <HBox spacing="20.0" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                                                    <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                        <Label text="Распределение по банкам" style="-fx-font-weight: bold;" />
                                                        <PieChart fx:id="depositBankChart" prefWidth="280" prefHeight="280" maxWidth="Infinity" maxHeight="Infinity" />
                                                    </VBox>
                                                    <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                        <Label text="Доходность по вкладам" style="-fx-font-weight: bold;" />
                                                        <PieChart fx:id="depositIncomeChart" prefWidth="280" prefHeight="280" maxWidth="Infinity" maxHeight="Infinity" />
                                                    </VBox>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </AnchorPane>
                            </content>
                        </Tab>

                        <!-- ==================== ВКЛАДКА "КРЕДИТЫ" (исправлены размеры диаграмм) ==================== -->
                        <Tab text="Кредиты">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                                    <children>
                                        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
                                            <children>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Button fx:id="addCreditButton" mnemonicParsing="false" text="Добавить кредит">
                                                            <HBox.margin>
                                                                <Insets left="10.0" />
                                                            </HBox.margin>
                                                        </Button>
                                                        <Button fx:id="deleteCreditButton" mnemonicParsing="false" text="Удалить кредит" />
                                                        <Button fx:id="payCreditButton" mnemonicParsing="false" text="Внести платеж" />
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="creditTable" prefHeight="229.0" prefWidth="513.0">
                                                    <columns>
                                                        <TableColumn fx:id="cre_numberColumn" prefWidth="50.0" text="№" />
                                                        <TableColumn fx:id="cre_bankColumn" prefWidth="100.0" text="Банк" />
                                                        <TableColumn fx:id="cre_initialAmountColumn" prefWidth="100.0" text="Сумма кредита" />
                                                        <TableColumn fx:id="cre_remainingAmountColumn" prefWidth="120.0" text="Остаток" />
                                                        <TableColumn fx:id="cre_percentColumn" prefWidth="60.0" text="\%" />
                                                        <TableColumn fx:id="cre_monthlyPaymentColumn" prefWidth="100.0" text="Платёж/мес" />
                                                        <TableColumn fx:id="cre_monthsColumn" prefWidth="60.0" text="Срок (мес)" />
                                                        <TableColumn fx:id="cre_openDateColumn" prefWidth="110.0" text="Дата открытия" />
                                                        <TableColumn fx:id="cre_closeDateColumn" prefWidth="110.0" text="Дата погашения" />
                                                        <TableColumn fx:id="cre_overpaymentColumn" prefWidth="100.0" text="Переплата" />
                                                    </columns>
                                                </TableView>
                                                <!-- Общая задолженность -->
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Label fx:id="creditTotalLabel" text="Общая задолженность: 0 руб" style="-fx-font-weight: bold; -fx-text-fill: #dc143c; -fx-padding: 5 0 5 10;" />
                                                </HBox>
                                                <!-- Диаграммы (исправлены размеры) -->
                                                <HBox spacing="20.0" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                                                    <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                        <Label text="Задолженность по банкам" style="-fx-font-weight: bold;" />
                                                        <PieChart fx:id="creditBankChart" prefWidth="280" prefHeight="280" maxWidth="Infinity" maxHeight="Infinity" />
                                                    </VBox>
                                                    <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                        <Label text="Переплата по кредитам" style="-fx-font-weight: bold;" />
                                                        <PieChart fx:id="creditOverpaymentChart" prefWidth="280" prefHeight="280" maxWidth="Infinity" maxHeight="Infinity" />
                                                    </VBox>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </AnchorPane>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>

                <!-- Кнопка редактирования внизу -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="bottom-panel">
                    <children>
                        <Button fx:id="editModeToggleButton" mnemonicParsing="false" text="Редактирование: ВЫКЛ" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>